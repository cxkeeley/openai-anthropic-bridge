# =============================================================================
# UNIVERSAL BRIDGE SETTINGS
# This file controls the bridge infrastructure itself.
# Per-project model behavior (persona, tools, rules) lives in each project's
# .claude/settings.json — NOT here.
# =============================================================================

# --- Connection ---
# Jiutian Target URL Endpoint
JTIU_TARGET_URL=https://ai.asix.id/kunlun/ingress/api-safe/5351ea/a95e59932d094883945ed08ab2a1f6bc/ai-4f4f1bee55324e7382a864176dbdd8da/service-2c125598e6b543c8a8859570f5688811/v1/chat/completions

# Your secure JWT access token
JTIU_TOKEN=YOUR_TOKEN_HERE

# Target model alias (default jt_indonesia, override with qwen3-coder-next for coding tasks)
JTIU_MODEL=jt_indonesia

# Custom System Persona / Role Override
# Switch between these roles by uncommenting one and commenting out the others.
JTIU_SYSTEM_OVERRIDE=""

# SSL Verification (set to false if using self-signed certs)
JTIU_SSL_VERIFY=true

# Docker / Local Service bindings
HOST=0.0.0.0
PORT=8000

# Rate Limiting Configuration
# JTIU_RATE_LIMIT_ENABLED=true
# JTIU_RATE_LIMIT_REQUESTS=10
# JTIU_RATE_LIMIT_WINDOW=60.0

# Model Parameters (JSON format)
JTIU_MODEL_PARAMS='{"text": {"temperature": 0.2, "max_tokens": 8192, "presence_penalty": 1.1, "frequency_penalty": 0.3, "top_p": 0.9}}'

# Upstream Configuration
JTIU_UPSTREAM_TIMEOUT=600.0

# Request & Response Payload Limits
JTIU_MAX_PAYLOAD_SIZE=10485760

# Connection Retry Backoff Configuration
JTIU_RETRY_MAX_ATTEMPTS=3
JTIU_RETRY_BASE_DELAY=1.0

# Logging Level (DEBUG, INFO, WARNING, ERROR, CRITICAL)
JTIU_LOG_LEVEL=INFO