# =============================================================================
# UNIVERSAL BRIDGE SETTINGS
# This file controls the bridge infrastructure itself.
# Per-project model behavior (persona, tools, rules) lives in each project's
# .claude/settings.json — NOT here.
# =============================================================================

# --- Connection ---
# Bridge Target URL Endpoint
BRIDGE_TARGET_URL=https://ai.asix.id/kunlun/ingress/api-safe/5351ea/a95e59932d094883945ed08ab2a1f6bc/ai-4f4f1bee55324e7382a864176dbdd8da/service-2c125598e6b543c8a8859570f5688811/v1/chat/completions

# Your secure JWT access token
BRIDGE_TOKEN=YOUR_TOKEN_HERE

# Target model alias (default jt_indonesia, override with qwen3-coder-next for coding tasks)
BRIDGE_MODEL=jt_indonesia

# Custom System Persona / Role Override
# Switch between these roles by uncommenting one and commenting out the others.
BRIDGE_SYSTEM_OVERRIDE=""

# SSL Verification (set to false if using self-signed certs)
BRIDGE_SSL_VERIFY=true

# Docker / Local Service bindings
HOST=0.0.0.0
PORT=8000

# Rate Limiting Configuration
# BRIDGE_RATE_LIMIT_ENABLED=true
# BRIDGE_RATE_LIMIT_REQUESTS=10
# BRIDGE_RATE_LIMIT_WINDOW=60.0

# Model Parameters
BRIDGE_TEMPERATURE=0.0
BRIDGE_MAX_TOKENS=131072
BRIDGE_PRESENCE_PENALTY=0.0
BRIDGE_FREQUENCY_PENALTY=0.0
BRIDGE_TOP_P=0.95

# Upstream Configuration
BRIDGE_UPSTREAM_TIMEOUT=600.0

# Request & Response Payload Limits
BRIDGE_MAX_PAYLOAD_SIZE=10485760

# Connection Retry Backoff Configuration
BRIDGE_RETRY_MAX_ATTEMPTS=3
BRIDGE_RETRY_BASE_DELAY=1.0

# Logging Level (DEBUG, INFO, WARNING, ERROR, CRITICAL)
BRIDGE_LOG_LEVEL=INFO
