{
  "permissions": {
    "allow": [
      // ── File operations ──────────────────────────────────────────
      "Write",
      "Edit",
      "MultiEdit",

      // ── Shell utilities (read-only, low risk) ────────────────────
      "Bash(cat *)",
      "Bash(grep *)",
      "Bash(find *)",
      "Bash(head *)",
      "Bash(tail *)",
      "Bash(ls *)",
      "Bash(wc *)",
      "Bash(sort *)",
      "Bash(echo *)",
      "Bash(printf *)",
      "Bash(which *)",
      "Bash(env *)",
      "Bash(pwd)",

      // ── File management ──────────────────────────────────────────
      "Bash(mkdir *)",
      "Bash(cp *)",
      "Bash(mv *)",
      "Bash(chmod *)",
      "Bash(tee *)",
      "Bash(touch *)",

      // ── Git & GitHub/GitLab ──────────────────────────────────────
      // Destructive git ops (force push, reset --hard) are caught by
      // the block-destructive hook below.
      "Bash(git *)",
      "Bash(gh *)",
      "Bash(glab *)",

      // ── Docker ──────────────────────────────────────────────────
      "Bash(docker *)",
      "Bash(docker-compose *)",

      // ── Node.js ─────────────────────────────────────────────────
      "Bash(npm *)",
      "Bash(npx *)",
      "Bash(yarn *)",
      "Bash(pnpm *)",
      "Bash(node *)",
      "Bash(bun *)",

      // ── Python ──────────────────────────────────────────────────
      "Bash(python *)",
      "Bash(python3 *)",
      "Bash(*/python *)",
      "Bash(*/python3 *)",
      "Bash(ruff *)",
      "Bash(*/ruff *)",
      "Bash(uv *)",
      "Bash(*/uv *)",
      "Bash(pip *)",
      "Bash(*/pip *)",
      "Bash(source *)",
      "Bash(pytest *)",
      "Bash(*/pytest *)",

      // ── Other runtimes ───────────────────────────────────────────
      "Bash(go *)",
      "Bash(cargo *)",
      "Bash(make *)",
      "Bash(curl *)",
      "Bash(jq *)",

      // ── Toolkit bin scripts ──────────────────────────────────────
      "Bash(~/.claude/bin/*)",

      // ── System ──────────────────────────────────────────────────
      "Read(~/.claude/**)",
      "Write(/tmp/*)",
      "Edit(/tmp/*)"
    ],
    "deny": [
      // Hard deny — the hook below also catches these with a clear reason
      "Bash(rm -rf /)",
      "Bash(rm -rf /*)",
      "Bash(rm -rf ~)"
    ],
    "additionalDirectories": [
      "/tmp"
    ]
  },

  // ── Hooks ──────────────────────────────────────────────────────────
  // Hooks run in ALL permission modes, including bypass-permissions.
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            // Auto-approves safe compound commands that permission matching
            // blocks because they start with 'for', '&&', or have redirects.
            "type": "command",
            "command": "~/.claude/bin/hook-auto-approve-bash.sh"
          },
          {
            // Blocks destructive patterns: rm -rf, force push, DROP TABLE, etc.
            // Exit code 2 = block with reason sent to Claude.
            "type": "command",
            "command": "~/.claude/bin/hook-block-destructive.sh"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        // Run ruff on Python files after Write/Edit — advisory, non-blocking.
        "matcher": "Write|Edit",
        "hooks": [
          {
            "type": "command",
            "command": "~/.claude/bin/hook-post-edit-lint.sh"
          }
        ]
      }
    ]
  }
}
