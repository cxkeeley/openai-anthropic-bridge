{
  "model": "claude-opus-4-7",
  "maxOutputTokens": 8192,
  "temperature": 0.2,
  "topP": 0.9,
  "thinking": {
    "type": "enabled",
    "budgetTokens": 16000
  },
  "tools": [
    {
      "name": "Bash",
      "description": "Execute shell commands",
      "inputSchema": {
        "type": "object",
        "properties": {
          "command": {
            "type": "string",
            "description": "The shell command to execute"
          }
        },
        "required": ["command"]
      }
    },
    {
      "name": "Read",
      "description": "Read files",
      "inputSchema": {
        "type": "object",
        "properties": {
          "file_path": {
            "type": "string",
            "description": "Path to the file to read"
          }
        },
        "required": ["file_path"]
      }
    },
    {
      "name": "Write",
      "description": "Write files",
      "inputSchema": {
        "type": "object",
        "properties": {
          "file_path": {
            "type": "string",
            "description": "Path to the file to write"
          },
          "content": {
            "type": "string",
            "description": "Content to write to the file"
          }
        },
        "required": ["file_path", "content"]
      }
    }
  ],
  "memory": {
    "enabled": true,
    "path": "/mnt/projectone/openai-anthropic-bridge/.claude/memory"
  },
  "hooks": {
    "SessionStart": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "git status",
            "description": "Initialize project context on start"
          },
          {
            "type": "command",
            "command": "git log --oneline -5"
          }
        ]
      }
    ],
    "SessionEnd": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "echo 'Session saved'"
          }
        ]
      }
    ]
  },
  "permissions": {
    "allow": [
      "Read",
      "Write",
      "Bash"
    ],
    "deny": []
  },
  "autoApprove": [
    "Read",
    "Write"
  ]
}
